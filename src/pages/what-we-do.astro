---
import Base from '@layouts/Base.astro';
import Tag from '@components/Tag.astro';
import SectionLabel from '@components/SectionLabel.astro';
import ServiceRows from '@components/ServiceRows.astro';
import ContactCTA from '@components/ContactCTA.astro';

const title = 'What We Do — Design, production and digital | Group 24/7 Worldwide';
const description =
  'Packaging, Point of Sale, Digital, Advertising & Collateral, Video, and pharma eDetailers — the services we deliver, with dedicated people and a workflow adapted to each account, across five offices.';
---
<Base title={title} description={description} route="what-we-do">
  <div class="page">
    <section class="page-header">
      <div class="shell">
        <div class="breadcrumb">
          <Tag dot={false}>↤ Home</Tag>
          <Tag dot={false} num="00 / 01">What we do</Tag>
        </div>
        <h1 class="h1 title reveal">
          The right<br />
          <span style="color: var(--accent); font-style: italic; font-weight: 400">specialists,</span><br />
          <span class="stroke">around your brief.</span>
        </h1>
        <p class="lede reveal reveal-delay-1">
          Different briefs need different specialists. We bring the right people together
          around yours — senior craft in every service, with the regional and specialist
          support each account needs, so the work stays joined-up from concept to delivery.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="shell">
        <ServiceRows />
      </div>
    </section>

    <section class="section bg-2">
      <div class="shell">
        <SectionLabel num="↳" name="Why one partner" right="Integrated brief, integrated team" />
        <div class="grid12">
          <div style="grid-column: span 6">
            <h2 class="h2 reveal">
              The handoff between agencies<br />
              <span style="color: var(--accent); font-style: italic; font-weight: 400">is where brands lose</span><br />
              consistency, money, and time.
            </h2>
          </div>
          <div style="grid-column: 8 / -1; align-self: end">
            <p class="lede reveal reveal-delay-1">
              One accountable partner across packaging, retail, digital and video means a
              team that knows your brand, a clear way of working that fits your business, and
              fewer handoffs on everything you ship.
            </p>
          </div>
        </div>
      </div>
    </section>

    <ContactCTA />
  </div>
</Base>
