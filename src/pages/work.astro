---
import Base from '@layouts/Base.astro';
import Tag from '@components/Tag.astro';
import Chip from '@components/Chip.astro';
import Placeholder from '@components/Placeholder.astro';
import SectionLabel from '@components/SectionLabel.astro';
import ContactCTA from '@components/ContactCTA.astro';
import { WORK, CASE_STUDIES } from '@data/site';

const title = 'Selected Work — Proof, not just labels | Group 24/7 Worldwide';
const description =
  'Recent G247 engagements told as challenge → what we delivered → practical value. De-identified mini case studies across pharma, FMCG, finserv, healthcare and retail.';

const industries = ['All', ...Array.from(new Set(WORK.map((w) => w.industry)))];
---
<Base title={title} description={description} route="work">
  <div class="page">
    <section class="page-header">
      <div class="shell">
        <div class="breadcrumb">
          <Tag dot={false}>↤ Home</Tag>
          <Tag dot={false} num="00 / 04">Selected work</Tag>
        </div>
        <h1 class="h1 title reveal">
          Selected work.<br />
          <span style="color: var(--accent); font-style: italic; font-weight: 400">Shipped, not pitched.</span>
        </h1>
        <p class="lede reveal reveal-delay-1">
          Each example below is told the way buyers actually weigh it up: the challenge, what we
          delivered, and the practical value. Many client projects are under NDA, so some are
          de-identified — happy to walk you through the full portfolio in a short call.
        </p>
      </div>
    </section>

    <!-- MINI CASE STUDIES -->
    <section class="section">
      <div class="shell">
        <SectionLabel num="01" name="Case studies" right="Challenge · Delivered · Value" />
        <div class="cases">
          {CASE_STUDIES.map((c) => (
            <article class="case reveal">
              <div class="case-head">
                <span class="mono accent">{c.sector}</span>
                <span class="mono muted">{c.scope}</span>
              </div>
              <div class="case-body">
                <div class="case-col">
                  <div class="case-label">Challenge</div>
                  <p>{c.challenge}</p>
                </div>
                <div class="case-col">
                  <div class="case-label">What we delivered</div>
                  <p>{c.delivered}</p>
                </div>
                <div class="case-col">
                  <div class="case-label">Practical value</div>
                  <p>{c.value}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
        <p class="mono muted reveal" style="margin-top: var(--s-6)">
          ↳ De-identified examples while we finalise approved, named case studies.
        </p>
      </div>
    </section>

    <!-- SELECTED WORK GRID -->
    <section class="section bg-2">
      <div class="shell">
        <SectionLabel num="02" name="More selected work" right="2024 → 2026" />
        <div class="row between" style="margin-bottom: var(--s-7); flex-wrap: wrap; gap: 16px">
          <div class="row gap-3" style="flex-wrap: wrap" id="work-filters">
            {industries.map((i) => (
              <button class:list={['chip', 'work-filter', i === 'All' && 'is-active']} data-filter={i}>{i}</button>
            ))}
          </div>
          <div class="mono muted" id="work-count">{WORK.length} of {WORK.length} projects</div>
        </div>

        <div class="work" id="work-grid">
          {WORK.map((w, i) => (
            <div class="work-card reveal" data-industry={w.industry} style={`grid-column: span ${w.size}; transition-delay: ${(i % 3) * 60}ms`}>
              <Placeholder ratio={w.ratio} label={`${w.year} · ${w.industry.toUpperCase()}`} />
              <div class="meta">
                <div>
                  <div class="mono muted">{w.kind} · {w.year}</div>
                  <div class="title" style="margin-top: 6px">{w.title}</div>
                </div>
                <Chip>{w.industry}</Chip>
              </div>
              <p class="work-value">{w.value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <ContactCTA />
  </div>
</Base>

<script>
  const total = document.querySelectorAll('#work-grid .work-card').length;
  const filters = document.querySelectorAll<HTMLButtonElement>('.work-filter');
  const cards = document.querySelectorAll<HTMLElement>('#work-grid .work-card');
  const count = document.getElementById('work-count');
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const f = btn.dataset.filter!;
      filters.forEach((b) => b.classList.toggle('is-active', b === btn));
      let shown = 0;
      cards.forEach((c) => {
        const match = f === 'All' || c.dataset.industry === f;
        c.style.display = match ? '' : 'none';
        if (match) shown++;
      });
      if (count) count.textContent = `${shown} of ${total} projects`;
    });
  });
</script>

<style>
  .work-filter { cursor: none; transition: border-color .2s, color .2s; }
  .work-filter.is-active { border-color: var(--accent); color: var(--accent); }
  @media (hover: none) { .work-filter { cursor: pointer; } }
</style>
