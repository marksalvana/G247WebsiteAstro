---
import Btn from './Btn.astro';
---
<section class="cta">
  <div class="shell">
    <div class="cta-display">
      Tell us<br />
      <span class="stroke">what you're</span><br />
      <span class="ital">shipping.</span>
    </div>
    <div class="cta-row">
      <p class="lede" style="max-width: 560px">
        One short brief is enough to start. We'll come back with a senior point of view,
        a clear plan, and a realistic timeline.
      </p>
      <Btn href="/contact" accent>Start a project</Btn>
    </div>
  </div>
</section>
