---
import Btn from './Btn.astro';
---
<section class="cta">
  <div class="shell">
    <div class="cta-display">
      Let's <span class="ital">work.</span><br />
      <span class="stroke">Faster, smarter,</span><br />
      better.
    </div>
    <div class="cta-row">
      <p class="lede" style="max-width: 560px">
        One short brief is enough to start. We'll come back to you with a senior point of
        view and an honest plan.
      </p>
      <Btn href="/contact" accent>Start a project</Btn>
    </div>
  </div>
</section>
