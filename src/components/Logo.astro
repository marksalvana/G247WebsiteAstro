---
/**
 * Group 24/7 Worldwide — animated "20 Years of Creativity" banner.
 * Served straight from /public as an animated WebP (kept out of Astro's
 * image pipeline so all frames survive); loops on its own, no JS.
 */
interface Props { class?: string; }
const { class: cls } = Astro.props;
---
<img
  class:list={['logo', cls]}
  src="/logo.webp"
  width="728"
  height="180"
  alt="20 Years of Creativity — Group 24/7 Worldwide"
  decoding="async"
  fetchpriority="high"
/>
