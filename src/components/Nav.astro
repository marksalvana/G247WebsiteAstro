---
import Clock from './Clock.astro';
import Logo from './Logo.astro';
import { NAV_ITEMS } from '@data/site';
interface Props { route?: string; }
const { route = 'home' } = Astro.props;
const isActive = (id: string) =>
  route === id || (id !== 'home' && route.startsWith(id));
---
<header class="nav">
  <div class="nav-inner">
    <a class="brand" href="/" aria-label="Group 24/7 Worldwide" data-cursor="default">
      <Logo class="brand-logo" />
    </a>
    <nav class="nav-menu" aria-label="Primary">
      {NAV_ITEMS.map((it) => (
        <a href={it.href} class:list={['nav-link', isActive(it.id) && 'active']}>{it.label}</a>
      ))}
    </nav>
    <div class="nav-right">
      <Clock class="nav-clock" tz="Australia/Sydney" label="SYD" />
      <button class="ai-trigger" type="button" data-ai-open aria-haspopup="dialog">
        <span class="ai-spark">✦</span>
        Ask G247
        <span class="ai-kbd">⌘K</span>
      </button>
      <button class="nav-burger" type="button" data-nav-toggle aria-label="Open menu" aria-expanded="false" aria-controls="nav-drawer">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
<div class="nav-drawer" id="nav-drawer" data-nav-drawer>
  <nav class="nav-drawer-menu" aria-label="Mobile">
    {NAV_ITEMS.map((it) => (
      <a href={it.href} class:list={['nav-drawer-link', isActive(it.id) && 'active']}>{it.label}</a>
    ))}
  </nav>
  <a class="btn btn-accent nav-drawer-cta" href="/contact">Start a project</a>
</div>
